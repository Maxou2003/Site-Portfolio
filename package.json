{
  "name": "portfolio-maxence",
  "version": "1.0.0",
  "description": "Portfolio fullstack pour Maxence Martin",
  "scripts": {
    "setup": "cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w frontend",
    "backend": "npm run dev -w backend",
    "frontend": "npm run dev -w frontend"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
